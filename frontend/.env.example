# PostgreSQL connection string (from Render, Supabase, Neon, etc.)
DATABASE_URL=postgresql://USER:PASSWORD@HOST/DATABASE

# URL of your deployed FastAPI backend (e.g. https://pricehawk-backend.onrender.com)
FASTAPI_URL=https://your-backend.onrender.com

# Optional — Redis for caching (leave blank to disable)
# REDIS_URL=redis://...
